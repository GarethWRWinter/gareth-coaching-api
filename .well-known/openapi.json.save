git add .well-known/openapi.json
git commit -m "Fix OpenAPI version to 3.1.0 for plugin compatibility"
git push origin main
XXXX{
  "openapi": "3.1.0",
  "info": {
    "title": "Gareth's Coaching API",
    "version": "1.0.0",
    "description": "Access Gareth's latest rides, metrics, and training insights."
  },
  "servers": [
    {
      "url": "https://gareth-coaching-api.onrender.com"
    }
  ],
  "paths": {
    "/latest-fit": {
      "get": {
        "summary": "Get the latest FIT file ride data",
        "operationId": "getLatestFit",
        "responses": {
          "200": {
            "description": "Latest ride data in JSON format"
          }
        }
      }
    },
    "/ride-report": {
      "get": {
        "summary": "Get the most recent ride report PDF",
        "operationId": "getRideReport",
        "responses": {
          "200": {
            "description": "PDF ride report"
          }
        }
      }
    },
    "/history": {
      "get": {
        "summary": "View all historical ride summaries",
        "operationId": "getRideHistory",
        "responses": {
          "200": {
            "description": "CSV or JSON ride history"
          }
        }
      }
    }
  }
}
